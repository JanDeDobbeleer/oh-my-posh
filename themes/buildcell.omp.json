{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "black": "#282c34",
    "red": "#e06c75",
    "green": "#98c379",
    "yellow": "#e5c07b",
    "blue": "#61afef",
    "magenta": "#c678dd",
    "cyan": "#56b6c2",
    "white": "#dcdfe4",
    "indigo": "#536dfe",
    "foreground": "#dcdfe4",
    "background": "#282c34"
  },
  "terminal_background": "p:background",
  "console_title_template": "{{ .UserName }}@{{ .HostName }}",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:cyan",
          "style": "plain",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "foreground": "p:blue",
          "style": "plain",
          "options": {
            "style": "full"
          },
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "options": {
            "fetch_status": true
          },
          "style": "plain",
          "template": "({{ if or (.Working.Changed) (.Staging.Changed) (gt .StashCount 0) }}<p:magenta>{{ .HEAD }}</>{{ else }}<p:green>{{ .HEAD }}</>{{ end }}{{ if .LatestTag }} <p:yellow>🏷 {{ .LatestTag }}</>{{ end }}{{ if (gt .Ahead 0)}}<p:cyan>{{ .BranchStatus }}</>{{ end }}{{ if (gt .Behind 0)}}<p:cyan>{{ .BranchStatus }}</>{{ end }}{{ if .Staging.Changed }} <p:green>{{ .Staging.String }}</>{{ end }}{{ if .Working.Changed }} <p:red>{{ .Working.String }}</>{{ end }})",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "python",
          "style": "powerline",
          "foreground": "#D4E157",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} <transparent>\ue0b6</>"
        },
        {
          "type": "node",
          "style": "powerline",
          "foreground": "#6CA35E",
          "template": "  {{ .Full }} "
        },
        {
          "type": "bun",
          "style": "powerline",
          "foreground": "p:cyan",
          "template": "  {{ .Full }} "
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "foreground": "#7c4dff",
          "template": "  {{ .Full }} "
        },
        {
          "type": "project",
          "style": "powerline",
          "foreground": "p:yellow",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Version }} {{.Version}}{{ end }} {{ if .Name }}{{ .Name }}{{ end }}{{ end }} "
        },
        {
          "type": "docker",
          "style": "powerline",
          "foreground": "#0B59E7",
          "template": "  {{ .Context }} "
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:foreground",
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "{{ if gt .Code 0 }}<p:red>({{ .Code }}) </>{{ else }}<p:green>({{ .Code }}) </>{{ end }}> ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 3
}
