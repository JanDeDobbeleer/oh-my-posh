{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#80CBC4",
          "style": "plain",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#80CBC4",
          "foreground": "#263238",
          "leading_diamond": "о‚¶",
          "style": "diamond",
          "template": "zsh оћ• ",
          "trailing_diamond": "о‚ґ",
          "type": "text"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "options": {
            "home_icon": "~",
            "style": "full"
          },
          "leading_diamond": "<transparent,#263238>о‚ґ</>",
          "style": "diamond",
          "template": "пЃ»  {{ .Path }} ",
          "trailing_diamond": "о‚ґ",
          "type": "path"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "powerline_symbol": "о‚ґ",
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " пђ€  {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} пЃ„ {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }} пЃ† {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0}}о­‹ {{ .StashCount }}{{ end }}{{ if gt .WorktreeCount 0}} п†» {{ .WorktreeCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "#37474F",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#37474F{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c57f33{{ end }}",
            "{{ if gt .Ahead 0 }}#79c533{{ end }}",
            "{{ if gt .Behind 0 }}#c53379{{ end }}"
          ],
          "foreground": "#263238",
          "powerline_symbol": "о‚ґ",
          "options": {
            "fetch_status": false,
            "fetch_upstream_icon": false
          },
          "style": "powerline",
          "template": "п„…",
          "type": "git"
        },
        {
          "leading_diamond": "<transparent,#49404f>о‚ґ</>",
          "style": "plain",
          "trailing_diamond": "о‚ґ",
          "type": "text"
        },
        {
          "background": "#80CBC4",
          "foreground": "#263238",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#a30000{{ end }}"
          ],
          "leading_diamond": "<transparent,#80CBC4>о‚ґ</>",
          "options": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": " {{ if gt .Code 0 }}пђЎ п„™ {{ else }}п‘© в™Ґ {{ end }}",
          "trailing_diamond": "о‚ґ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "leading_diamond": "о‚¶",
          "style": "diamond",
          "template": " о‰¦ {{ round .PhysicalPercentUsed .Precision }}% | RAM: {{ round (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) 1 }}/{{ round (div .PhysicalTotalMemory 1073741824.0) 0 }}GB <#111111>о‚¶</>",
          "type": "sysinfo"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "leading_diamond": "о‚¶",
          "style": "diamond",
          "template": " п‚¬ <#111111>о‚¶</>",
          "type": "text"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "invert_powerline": true,
          "leading_diamond": "о‚¶",
          "options": {
            "always_enabled": true,
            "charged_icon": "п‰Ђ ",
            "charging_icon": "пѓ§ ",
            "discharging_icon": "п‰ѓ ",
            "not_charging_icon": "п‰Ђ "
          },
          "style": "diamond",
          "template": " {{ .Icon }}{{ .Percentage }}% <#111111>о‚¶</>",
          "type": "battery"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "invert_powerline": true,
          "leading_diamond": "о‚¶",
          "options": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": " о®ў {{ .FormattedMs }} <#111111>о‚¶</>",
          "type": "executiontime"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "invert_powerline": true,
          "leading_diamond": "о‚¶",
          "options": {
            "time_format": "02 Jan Mon 15:04:05"
          },
          "style": "diamond",
          "template": " пЃі {{ .CurrentDate | date .Format }}",
          "trailing_diamond": "о‚ґ",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#263238",
          "style": "plain",
          "template": "оѓ…",
          "type": "text"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "powerline_symbol": "оѓ„",
          "style": "powerline",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#263238",
          "foreground": "#80CBC4",
          "powerline_symbol": "о‚ґ",
          "style": "powerline",
          "template": "пѓ§ ",
          "type": "root"
        },
        {
          "background": "#80CBC4",
          "foreground": "#263238",
          "powerline_symbol": "о‚ґ",
          "style": "powerline",
          "template": " {{ if .SSHSession }}о®© {{ end }}{{ .UserName }} ",
          "type": "session"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}Admin: {{end}} {{.Folder}}",
  "final_space": true,
  "version": 4
}
