{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "background": "transparent",
                    "style": "plain",
                    "template": "\u256d\u2500",
                    "foreground_templates": [
                        "{{ if eq .OS \"alpine\" }}#a8b9cc{{ end }}",
                        "{{ if eq .OS \"arch\" }}#1793d1{{ end }}",
                        "{{ if eq .OS \"centos\" }}#932279{{ end }}",
                        "{{ if eq .OS \"debian\" }}#a80030{{ end }}",
                        "{{ if eq .OS \"elementary\" }}#44a0dd{{ end }}",
                        "{{ if eq .OS \"fedora\" }}#51a2da{{ end }}",
                        "{{ if eq .OS \"gentoo\" }}#54487a{{ end }}",
                        "{{ if eq .OS \"linux\" }}#3a3a3a{{ end }}",
                        "{{ if eq .OS \"macos\" }}#000000{{ end }}",
                        "{{ if eq .OS \"manjaro\" }}#35bfa4{{ end }}",
                        "{{ if eq .OS \"mint\" }}#69b53f{{ end }}",
                        "{{ if eq .OS \"opensuse\" }}#73ba25{{ end }}",
                        "{{ if eq .OS \"raspbian\" }}#cd2355{{ end }}",
                        "{{ if eq .OS \"ubuntu\" }}#e75320{{ end }}",
                        "{{ if eq .OS \"windows\" }}#0078d7{{ end }}"
                    ],
                    "type": "text"
                },
                {
                    "background": "transparent",
                    "foreground": "p:white",
                    "style": "root",
                    "template": "\uf489 ",
                    "background_templates": [
                        "{{ if eq .OS \"alpine\" }}#a8b9cc{{ end }}",
                        "{{ if eq .OS \"arch\" }}#1793d1{{ end }}",
                        "{{ if eq .OS \"centos\" }}#932279{{ end }}",
                        "{{ if eq .OS \"debian\" }}#a80030{{ end }}",
                        "{{ if eq .OS \"elementary\" }}#44a0dd{{ end }}",
                        "{{ if eq .OS \"fedora\" }}#51a2da{{ end }}",
                        "{{ if eq .OS \"gentoo\" }}#54487a{{ end }}",
                        "{{ if eq .OS \"linux\" }}#3a3a3a{{ end }}",
                        "{{ if eq .OS \"macos\" }}#000000{{ end }}",
                        "{{ if eq .OS \"manjaro\" }}#35bfa4{{ end }}",
                        "{{ if eq .OS \"mint\" }}#69b53f{{ end }}",
                        "{{ if eq .OS \"opensuse\" }}#73ba25{{ end }}",
                        "{{ if eq .OS \"raspbian\" }}#cd2355{{ end }}",
                        "{{ if eq .OS \"ubuntu\" }}#e75320{{ end }}",
                        "{{ if eq .OS \"windows\" }}#0078d7{{ end }}"
                    ],
                    "type": "text"
                },
                {
                    "type": "os",
                    "style": "plain",
                    "foreground": "#f2f3f8",
                    "template": " {{.Icon}}{{if .WSL}} (WSL){{end}}\u2800",
                    "background_templates": [
                        "{{ if eq .OS \"alpine\" }}#a8b9cc{{ end }}",
                        "{{ if eq .OS \"arch\" }}#1793d1{{ end }}",
                        "{{ if eq .OS \"centos\" }}#932279{{ end }}",
                        "{{ if eq .OS \"debian\" }}#a80030{{ end }}",
                        "{{ if eq .OS \"elementary\" }}#44a0dd{{ end }}",
                        "{{ if eq .OS \"fedora\" }}#51a2da{{ end }}",
                        "{{ if eq .OS \"gentoo\" }}#54487a{{ end }}",
                        "{{ if eq .OS \"linux\" }}#3a3a3a{{ end }}",
                        "{{ if eq .OS \"macos\" }}#000000{{ end }}",
                        "{{ if eq .OS \"manjaro\" }}#35bfa4{{ end }}",
                        "{{ if eq .OS \"mint\" }}#69b53f{{ end }}",
                        "{{ if eq .OS \"opensuse\" }}#73ba25{{ end }}",
                        "{{ if eq .OS \"raspbian\" }}#cd2355{{ end }}",
                        "{{ if eq .OS \"ubuntu\" }}#e75320{{ end }}",
                        "{{ if eq .OS \"windows\" }}#0078d7{{ end }}"
                    ]
                },
                {
                    "type": "session",
                    "style": "powerline",
                    "foreground": "#f2f3f8",
                    "template": " \uf2c0 {{.HostName}} \ue0bd {{.UserName}}\u2800",
                    "background_templates": [
                        "{{ if eq .OS \"alpine\" }}#a8b9cc{{ end }}",
                        "{{ if eq .OS \"arch\" }}#1793d1{{ end }}",
                        "{{ if eq .OS \"centos\" }}#932279{{ end }}",
                        "{{ if eq .OS \"debian\" }}#a80030{{ end }}",
                        "{{ if eq .OS \"elementary\" }}#44a0dd{{ end }}",
                        "{{ if eq .OS \"fedora\" }}#51a2da{{ end }}",
                        "{{ if eq .OS \"gentoo\" }}#54487a{{ end }}",
                        "{{ if eq .OS \"linux\" }}#3a3a3a{{ end }}",
                        "{{ if eq .OS \"macos\" }}#000000{{ end }}",
                        "{{ if eq .OS \"manjaro\" }}#35bfa4{{ end }}",
                        "{{ if eq .OS \"mint\" }}#69b53f{{ end }}",
                        "{{ if eq .OS \"opensuse\" }}#73ba25{{ end }}",
                        "{{ if eq .OS \"raspbian\" }}#cd2355{{ end }}",
                        "{{ if eq .OS \"ubuntu\" }}#e75320{{ end }}",
                        "{{ if eq .OS \"windows\" }}#0078d7{{ end }}"
                    ]
                },
                {
                    "background": "#e4e4e4",
                    "foreground": "#585858",
                    "options": {
                        "style": "agnoster_short",
                        "max_depth": 3,
                        "folder_icon": "\u2026",
                        "folder_separator_icon": " <transparent>\ue0b1</> ",
                        "home_icon": "\ueb06"
                    },
                    "style": "powerline",
                    "powerline_symbol": "\ue0b0",
                    "template": " {{ .Path }} ",
                    "type": "path"
                },
                {
                    "background": "#378504",
                    "foreground": "#f2f3f8",
                    "background_templates": [
                        "{{ if or (.Working.Changed) (.Staging.Changed) }}#a97400{{ end }}",
                        "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#54433a{{ end }}",
                        "{{ if gt .Ahead 0 }}#744d89{{ end }}",
                        "{{ if gt .Behind 0 }}#744d89{{ end }}"
                    ],
                    "options": {
                        "branch_template": "{{ trunc 25 .Branch }}",
                        "fetch_status": true,
                        "branch_icon": "\uf418 ",
                        "branch_identical_icon": "\uf444",
                        "branch_gone_icon": "\ueab8"
                    },
                    "style": "diamond",
                    "leading_diamond": "<transparent,background>\ue0b0</>",
                    "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} <transparent>\ue0b1</> <#121318>\uf044 {{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }} <transparent>\ue0b1</> <#121318>\uf046 {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} <transparent>\ue0b1</> <#121318>\ueb4b {{ .StashCount }}</>{{ end }} ",
                    "trailing_diamond": "\ue0b0",
                    "type": "git"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "right",
            "segments": [
                {
                    "background": "#e4e4e4",
                    "foreground": "#585858",
                    "options": {
                        "style": "austin",
                        "always_enabled": true
                    },
                    "invert_powerline": true,
                    "style": "powerline",
                    "powerline_symbol": "\ue0b2",
                    "template": " \ueba2 {{ .FormattedMs }} ",
                    "type": "executiontime"
                },
                {
                    "background_templates": [
                        "{{ if eq .OS \"alpine\" }}#a8b9cc{{ end }}",
                        "{{ if eq .OS \"arch\" }}#1793d1{{ end }}",
                        "{{ if eq .OS \"centos\" }}#932279{{ end }}",
                        "{{ if eq .OS \"debian\" }}#a80030{{ end }}",
                        "{{ if eq .OS \"elementary\" }}#44a0dd{{ end }}",
                        "{{ if eq .OS \"fedora\" }}#51a2da{{ end }}",
                        "{{ if eq .OS \"gentoo\" }}#54487a{{ end }}",
                        "{{ if eq .OS \"linux\" }}#3a3a3a{{ end }}",
                        "{{ if eq .OS \"macos\" }}#000000{{ end }}",
                        "{{ if eq .OS \"manjaro\" }}#35bfa4{{ end }}",
                        "{{ if eq .OS \"mint\" }}#69b53f{{ end }}",
                        "{{ if eq .OS \"opensuse\" }}#73ba25{{ end }}",
                        "{{ if eq .OS \"raspbian\" }}#cd2355{{ end }}",
                        "{{ if eq .OS \"ubuntu\" }}#e75320{{ end }}",
                        "{{ if eq .OS \"windows\" }}#0078d7{{ end }}"
                    ],
                    "foreground": "#f2f3f8",
                    "options": {
                        "time_format": "15:04:05"
                    },
                    "invert_powerline": true,
                    "style": "powerline",
                    "template": " \uf073 {{ .CurrentDate | date .Format }} ",
                    "trailing_diamond": "\ue0b0",
                    "type": "time"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "style": "plain",
                    "template": "\u2570\u2500 {{ if .Root }}#{{else}}${{end}}",
                    "type": "text",
                    "foreground_templates": [
                        "{{ if eq .OS \"alpine\" }}#a8b9cc{{ end }}",
                        "{{ if eq .OS \"arch\" }}#1793d1{{ end }}",
                        "{{ if eq .OS \"centos\" }}#932279{{ end }}",
                        "{{ if eq .OS \"debian\" }}#a80030{{ end }}",
                        "{{ if eq .OS \"elementary\" }}#44a0dd{{ end }}",
                        "{{ if eq .OS \"fedora\" }}#51a2da{{ end }}",
                        "{{ if eq .OS \"gentoo\" }}#54487a{{ end }}",
                        "{{ if eq .OS \"linux\" }}#3a3a3a{{ end }}",
                        "{{ if eq .OS \"macos\" }}#000000{{ end }}",
                        "{{ if eq .OS \"manjaro\" }}#35bfa4{{ end }}",
                        "{{ if eq .OS \"mint\" }}#69b53f{{ end }}",
                        "{{ if eq .OS \"opensuse\" }}#73ba25{{ end }}",
                        "{{ if eq .OS \"raspbian\" }}#cd2355{{ end }}",
                        "{{ if eq .OS \"ubuntu\" }}#e75320{{ end }}",
                        "{{ if eq .OS \"windows\" }}#0078d7{{ end }}"
                    ]
                }
            ],
            "type": "prompt"
        }
    ],
    "final_space": true,
    "version": 4
}
