{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#F8BBD0",
          "style": "plain",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#880E4F",
          "style": "plain",
          "template": "",
          "type": "text"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "  ",
          "type": "text"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "options": {
            "home_icon": "",
            "style": "full"
          },
          "style": "diamond",
          "template": "{{ .Path }} ",
          "trailing_diamond": "",
          "type": "path"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "powerline_symbol": "",
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": "   {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0}} {{ .StashCount }}{{ end }}{{ if gt .WorktreeCount 0}}  {{ .WorktreeCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "#AD1457",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#AD1457{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c57f33{{ end }}",
            "{{ if gt .Ahead 0 }}#79c533{{ end }}",
            "{{ if gt .Behind 0 }}#c53379{{ end }}"
          ],
          "foreground": "#880E4F",
          "powerline_symbol": "",
          "options": {
            "fetch_status": false,
            "fetch_upstream_icon": false
          },
          "style": "powerline",
          "template": "",
          "type": "git"
        },
        {
          "leading_diamond": "<transparent,#49404f></>",
          "style": "plain",
          "trailing_diamond": "",
          "type": "text"
        },
        {
          "background": "#F8BBD0",
          "foreground": "#880E4F",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#a30000{{ end }}"
          ],
          "leading_diamond": "<transparent,#F8BBD0></>",
          "options": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": " {{ if gt .Code 0 }}  {{ else }} ♥ {{ end }}",
          "trailing_diamond": "",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "leading_diamond": "",
          "style": "diamond",
          "template": "  {{ round .PhysicalPercentUsed .Precision }}% | RAM: {{ round (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) 1 }}/{{ round (div .PhysicalTotalMemory 1073741824.0) 0 }}GB <#111111></>",
          "type": "sysinfo"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "leading_diamond": "",
          "style": "diamond",
          "template": "  <#111111></>",
          "type": "text"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "invert_powerline": true,
          "leading_diamond": "",
          "options": {
            "charged_icon": " ",
            "charging_icon": " ",
            "discharging_icon": " "
          },
          "style": "diamond",
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }}% <#111111></>",
          "type": "battery"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "invert_powerline": true,
          "leading_diamond": "",
          "options": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": "  {{ .FormattedMs }} <#111111></>",
          "type": "executiontime"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "invert_powerline": true,
          "leading_diamond": "",
          "options": {
            "time_format": "02 Jan Mon 15:04:05"
          },
          "style": "diamond",
          "template": "  {{ .CurrentDate | date .Format }}",
          "trailing_diamond": "",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#880E4F",
          "style": "plain",
          "template": "",
          "type": "text"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#880E4F",
          "foreground": "#F8BBD0",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " ",
          "type": "root"
        },
        {
          "background": "#F8BBD0",
          "foreground": "#880E4F",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .SSHSession }} {{ end }}{{ .UserName }} ",
          "type": "session"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}Admin: {{end}} {{.Folder}}",
  "final_space": true,
  "version": 4
}